# Copy this file to .env and fill in your actual API keys

# YouTube Data API Key
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# SerpAPI Key (Google Search)
# Get from: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_api_key_here

# OpenAI API Key
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Login — generar hash con: hashlib.pbkdf2_hmac('sha256', pwd.encode(), salt.encode(), 100000).hex()
LOGIN_SALT=your_random_salt_here
LOGIN_USER_SACVEN=hash_of_sacven_password
LOGIN_USER_PEDRO=hash_of_pedro_password
LOGIN_USER_INVITADO=hash_of_invitado_password
